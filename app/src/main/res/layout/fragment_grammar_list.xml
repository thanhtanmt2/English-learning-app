<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_grammar_list_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Grammar List Screen"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_grammar_list_to_add_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Add/Edit Grammar" />

    <Button
        android:id="@+id/btn_grammar_list_to_quiz"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Grammar Quiz" />
</LinearLayout>
